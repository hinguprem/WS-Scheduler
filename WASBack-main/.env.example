PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
DEFAULT_TIMEZONE=Asia/Kolkata

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/wa_scheduler?retryWrites=true&w=majority

JWT_SECRET=super_secret_key_change_me_in_production
JWT_EXPIRES_IN=7d

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your-email@gmail.com

APP_NAME=WA Scheduler
MAX_FILE_SIZE=16777216
